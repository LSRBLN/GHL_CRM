# --- Core app ---
# MongoDB connection string used by the FastAPI backend.
# If you expose MongoDB auth later, use: mongodb://USER:PASS@mongo:27017
MONGO_URL=mongodb://mongo:27017

# Database name the backend uses (Motor client selects this DB).
DB_NAME=lead_finder_42

# Comma-separated list of allowed browser origins for CORS.
# For same-origin deployments, set this to your domain and/or server IP.
CORS_ORIGINS=http://91.99.184.153,http://localhost

# --- Email (Resend) ---
RESEND_API_KEY=__PUT_YOUR_RESEND_API_KEY_HERE__
SENDER_EMAIL=__FROM_EMAIL@YOUR_DOMAIN__

# --- LLM / AI ---
# routes_llm.py uses ANTHROPIC_API_KEY OR EMERGENT_LLM_KEY.
ANTHROPIC_API_KEY=__PUT_KEY_HERE__
EMERGENT_LLM_KEY=__PUT_KEY_HERE__

# --- Google Places ---
GOOGLE_PLACES_API_KEY=__PUT_KEY_HERE__

# --- SEO / SERP ---
SERPAPI_API_KEY=__PUT_KEY_HERE__

# --- App security (optional today, but reserved) ---
SECRET_KEY=__GENERATE_A_LONG_RANDOM_SECRET__
